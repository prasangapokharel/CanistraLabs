# ICP Hosting Platform — Backend Environment
# Copy to backend/.env and fill in values before running.

ENVIRONMENT=development
DEBUG=true

# Required — local PostgreSQL (create user/db: see README)
DATABASE_URL=postgresql+asyncpg://icp:YOUR_PASSWORD@127.0.0.1:5432/icp
JWT_SECRET_KEY=change-me-to-a-random-string-at-least-32-chars

# Required in production — separate from JWT secret
ENCRYPTION_KEY=change-me-to-another-random-string-at-least-32-chars

# Required for cron/internal endpoints (X-Admin-Api-Key header)
ADMIN_API_KEY=change-me-admin-key-at-least-32-chars

# Comma-separated frontend origins (no wildcards with credentials)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ICP mainnet (real ICP) — production default
ICP_NETWORK=ic
DFX_NETWORK=ic
USE_TESTICP=false
ICP_LEDGER_CANISTER_ID=rrkah-fqaaa-aaaaa-aaaaq-cai
ROSETTA_URL=https://rosetta-api.internetcomputer.org

# Where canisters are deployed: ic (mainnet) or local (dfx replica)
DEPLOY_NETWORK=ic

# Local development with TESTICP faucet instead:
# USE_TESTICP=true
# TESTICP_LEDGER_CANISTER_ID=xafvr-biaaa-aaaai-aql5q-cai
# DEPLOY_NETWORK=local

# Pure local dfx (no real ICP):
# ICP_NETWORK=local
# DFX_NETWORK=local
# USE_TESTICP=false
# ROSETTA_URL=http://localhost:8082
# DEPLOY_NETWORK=local

# URLs
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# Redis / Celery (required for background deploys)
REDIS_URL=redis://localhost:6379
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
# Queue deploys via Celery; falls back to sync if Redis/worker unavailable
ASYNC_DEPLOY_ENABLED=true

# Email (optional)
EMAIL_SMTP_HOST=localhost
EMAIL_SMTP_PORT=587
EMAIL_FROM_EMAIL=noreply@yourdomain.com

# Auth policy
REQUIRE_EMAIL_VERIFICATION=false

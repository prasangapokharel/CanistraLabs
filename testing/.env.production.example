# ICP Hosting Platform - Production Environment Configuration
# Copy this file to .env and fill in your production values

# =============================================================================
# Application Settings
# =============================================================================
ENVIRONMENT=production
DEBUG=false
APP_NAME=Canistra
SECRET_KEY=your-super-secret-key-here-change-in-production
FRONTEND_URL=https://yourdomain.com
BACKEND_URL=https://api.yourdomain.com

# =============================================================================
# Database Configuration
# =============================================================================
DATABASE_URL=postgresql://username:password@hostname:5432/icp_hosting_db
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40

# =============================================================================
# Email Configuration - Choose ONE provider
# =============================================================================

# SendGrid (Recommended for most use cases)
SMTP_PROVIDER=sendgrid
SENDGRID_API_KEY=SG.your_api_key_here
SENDGRID_FROM_EMAIL=noreply@yourdomain.com
SENDGRID_FROM_NAME=Canistra

# OR AWS SES (for high volume, cost-sensitive)
# SMTP_PROVIDER=aws_ses
# AWS_SES_REGION=us-east-1
# AWS_SES_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
# AWS_SES_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
# AWS_SES_FROM_EMAIL=noreply@yourdomain.com

# OR Mailgun (for developer experience)
# SMTP_PROVIDER=mailgun
# MAILGUN_API_KEY=key-your_api_key_here
# MAILGUN_DOMAIN=mg.yourdomain.com
# MAILGUN_FROM_EMAIL=noreply@yourdomain.com

# OR Postmark (for transactional reliability)
# SMTP_PROVIDER=postmark
# POSTMARK_SERVER_TOKEN=your_server_token_here
# POSTMARK_FROM_EMAIL=noreply@yourdomain.com

# Email Settings
EMAIL_VERIFICATION_EXPIRY_HOURS=24
PASSWORD_RESET_EXPIRY_HOURS=1

# =============================================================================
# Authentication & Security
# =============================================================================
JWT_SECRET=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
BCRYPT_ROUNDS=12

# CORS Settings
CORS_ORIGINS=["https://yourdomain.com","https://www.yourdomain.com"]
CORS_ALLOW_CREDENTIALS=true

# =============================================================================
# ICP Configuration
# =============================================================================
ICP_NETWORK=ic
ICP_HOST=https://ic0.app
CANISTER_ID_API_GATEWAY=your_canister_id_here
CANISTER_ID_USER_REGISTRY=your_canister_id_here
CANISTER_ID_PROJECT_MANAGER=your_canister_id_here
CANISTER_ID_DEPLOY_ENGINE=your_canister_id_here
CANISTER_ID_BILLING=your_canister_id_here
CANISTER_ID_DOMAIN_MANAGER=your_canister_id_here
CANISTER_ID_METRICS_COLLECTOR=your_canister_id_here

# =============================================================================
# Wallet & Cycles Configuration
# =============================================================================
CYCLES_PER_PROJECT=100000000000  # 100B cycles per project
TESTNET_CYCLES_FAUCET_URL=https://testnet-cycles-faucet.example.com
TESTNET_CYCLES_AMOUNT=50000000000  # 50B cycles

# =============================================================================
# Wallet Integration (Plug/NFID)
# =============================================================================
PLUG_WHITELIST_CANISTERS=ryjl3-tyaaa-aaaaa-aaaba-cai,your_canister_id_here
NFID_DISCOVERY_CANISTER=nfid-discovery-canister-id

# =============================================================================
# API Configuration
# =============================================================================
API_VERSION=v1
API_RATE_LIMIT_REQUESTS=10000
API_RATE_LIMIT_PERIOD=3600  # seconds
API_REQUEST_TIMEOUT=30  # seconds
API_MAX_BODY_SIZE=52428800  # 50MB in bytes

# =============================================================================
# Logging Configuration
# =============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=/var/log/canistra/app.log
LOG_ROTATION_SIZE=104857600  # 100MB
LOG_RETENTION_DAYS=30

# =============================================================================
# Monitoring & Telemetry
# =============================================================================
SENTRY_DSN=https://your-sentry-dsn@sentry.io/12345
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# Prometheus Metrics
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# =============================================================================
# Security Settings
# =============================================================================
SECURE_COOKIES=true
SAME_SITE_COOKIES=Strict
HSTS_MAX_AGE=31536000  # 1 year in seconds
HSTS_INCLUDE_SUBDOMAINS=true
HSTS_PRELOAD=true

# =============================================================================
# File Upload Configuration
# =============================================================================
MAX_UPLOAD_SIZE=52428800  # 50MB
UPLOAD_STORAGE_PATH=/var/storage/uploads
ALLOWED_FILE_TYPES=["js","ts","jsx","tsx","json","html","css","wasm"]

# =============================================================================
# Third-Party Services
# =============================================================================
GITHUB_OAUTH_CLIENT_ID=your_client_id_here
GITHUB_OAUTH_CLIENT_SECRET=your_client_secret_here

# SendGrid Event Webhook
SENDGRID_WEBHOOK_SECRET=your_webhook_secret_here

# =============================================================================
# Performance Tuning
# =============================================================================
UVICORN_WORKERS=4
UVICORN_WORKER_CLASS=uvicorn.workers.UvicornWorker
CACHE_BACKEND=redis
CACHE_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=3600

# =============================================================================
# Feature Flags
# =============================================================================
FEATURE_PLUG_WALLET=true
FEATURE_NFID_WALLET=true
FEATURE_CUSTOM_DOMAINS=true
FEATURE_METRICS_DASHBOARD=true
FEATURE_GITHUB_INTEGRATION=false
FEATURE_GITHUB_AUTO_DEPLOY=false

# =============================================================================
# Production Safety Checks
# =============================================================================
REQUIRE_EMAIL_VERIFICATION=true
REQUIRE_STRONG_PASSWORD=true
ACCOUNT_LOCKOUT_ATTEMPTS=5
ACCOUNT_LOCKOUT_DURATION=900  # 15 minutes

# ICP Hosting Platform - Testnet Environment Configuration
# For IC testnet deployment

# =============================================================================
# Application Settings
# =============================================================================
ENVIRONMENT=testnet
DEBUG=false
APP_NAME=Perai
SECRET_KEY=testnet-secret-key-change-before-mainnet
FRONTEND_URL=https://testnet.perai.io
BACKEND_URL=https://api-testnet.perai.io

# =============================================================================
# Database Configuration
# =============================================================================
DATABASE_URL=postgresql://user:password@db.testnet.perai.io:5432/icp_hosting_db
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# =============================================================================
# Email Configuration - Production SMTP
# =============================================================================
SMTP_PROVIDER=smtp
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USERNAME=official@sunsari2.com
SMTP_PASSWORD=xXQv&h#Z2
SMTP_USE_TLS=false
SMTP_USE_SSL=true
SMTP_FROM_EMAIL=official@sunsari2.com
SMTP_FROM_NAME=Perai

# Email Settings
EMAIL_VERIFICATION_EXPIRY_HOURS=24
PASSWORD_RESET_EXPIRY_HOURS=1

# =============================================================================
# Authentication & Security
# =============================================================================
JWT_SECRET=testnet-jwt-secret-change-before-mainnet
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
BCRYPT_ROUNDS=12

# CORS Settings
CORS_ORIGINS=["https://testnet.perai.io","https://www.testnet.perai.io"]
CORS_ALLOW_CREDENTIALS=true

# =============================================================================
# ICP Configuration - TESTNET
# =============================================================================
ICP_NETWORK=ic
ICP_HOST=https://ic0.app
CANISTER_ID_API_GATEWAY=xxxxx-xxxxx-xxxxx-xxxxx-cai
CANISTER_ID_USER_REGISTRY=xxxxx-xxxxx-xxxxx-xxxxx-cai
CANISTER_ID_PROJECT_MANAGER=xxxxx-xxxxx-xxxxx-xxxxx-cai
CANISTER_ID_DEPLOY_ENGINE=xxxxx-xxxxx-xxxxx-xxxxx-cai
CANISTER_ID_BILLING=xxxxx-xxxxx-xxxxx-xxxxx-cai
CANISTER_ID_DOMAIN_MANAGER=xxxxx-xxxxx-xxxxx-xxxxx-cai
CANISTER_ID_METRICS_COLLECTOR=xxxxx-xxxxx-xxxxx-xxxxx-cai

# =============================================================================
# Wallet & Cycles Configuration
# =============================================================================
CYCLES_PER_PROJECT=100000000000
TESTNET_CYCLES_FAUCET_URL=https://faucet.dfinity.org
TESTNET_CYCLES_AMOUNT=50000000000

# =============================================================================
# Wallet Integration (Plug/NFID)
# =============================================================================
PLUG_WHITELIST_CANISTERS=ryjl3-tyaaa-aaaaa-aaaba-cai
NFID_DISCOVERY_CANISTER=nfid-discovery-canister-id

# =============================================================================
# API Configuration
# =============================================================================
API_VERSION=v1
API_RATE_LIMIT_REQUESTS=10000
API_RATE_LIMIT_PERIOD=3600
API_REQUEST_TIMEOUT=30
API_MAX_BODY_SIZE=52428800

# =============================================================================
# Logging Configuration
# =============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=/var/log/perai/app.log
LOG_ROTATION_SIZE=104857600
LOG_RETENTION_DAYS=30

# =============================================================================
# Monitoring & Telemetry
# =============================================================================
SENTRY_DSN=https://your-sentry-dsn@sentry.io/12345
SENTRY_ENVIRONMENT=testnet
SENTRY_TRACES_SAMPLE_RATE=0.1

PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# =============================================================================
# Performance Tuning
# =============================================================================
UVICORN_WORKERS=4
UVICORN_WORKER_CLASS=uvicorn.workers.UvicornWorker
CACHE_BACKEND=redis
CACHE_URL=redis://cache.testnet.perai.io:6379/0
CACHE_TTL_SECONDS=3600

# =============================================================================
# Feature Flags
# =============================================================================
FEATURE_PLUG_WALLET=true
FEATURE_NFID_WALLET=true
FEATURE_CUSTOM_DOMAINS=true
FEATURE_METRICS_DASHBOARD=true
FEATURE_GITHUB_INTEGRATION=false
FEATURE_GITHUB_AUTO_DEPLOY=false

# =============================================================================
# Security Settings
# =============================================================================
SECURE_COOKIES=true
SAME_SITE_COOKIES=Strict
HSTS_MAX_AGE=31536000
HSTS_INCLUDE_SUBDOMAINS=true
HSTS_PRELOAD=true
REQUIRE_EMAIL_VERIFICATION=true
REQUIRE_STRONG_PASSWORD=true
ACCOUNT_LOCKOUT_ATTEMPTS=5
ACCOUNT_LOCKOUT_DURATION=900
